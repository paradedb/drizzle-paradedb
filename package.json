    "drizzle-kit": "1.0.0-rc.2",
    "postgres": "^3.4.9",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "drizzle-orm": "1.0.0-rc.2"
  }
